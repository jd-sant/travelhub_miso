# Copiar este archivo a .env y ajustar los valores
JWT_SECRET_KEY=travelhub-jwt-secret-change-in-prod
INTERNAL_API_KEY=travelhub-internal-secret-key

# Email SMTP (Gmail) - dejar SMTP_HOST vacio para usar LogOtpSender (logs OTP en consola)
# Para Gmail: habilitar 2FA y crear App Password en https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password
SMTP_FROM=tu-email@gmail.com
