# Configuración de base de datos
DATABASE_URL=sqlite:///./reservations.db
RDS_HOSTNAME=localhost
RDS_PORT=5432
RDS_USERNAME=travelhub_user
RDS_PASSWORD=travelhub_pass
RDS_DB_NAME=travelhub

# Esquema del servicio de reservas
DB_SCHEMA=reservations_schema

# Depuración de base de datos (ponlo en True para ver logs SQL)
DB_ECHO=False

# Entorno
ENV=development
APP_ENV=development

# Clave API interna para comunicación entre servicios
INTERNAL_API_KEY=dev-internal-key-change-me
