              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HU016: request sin header TLS es rechazado', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('HU016: mensaje indica requerimiento de TLS', function () {",
                  "    pm.expect(body.detail).to.eql('TLS 1.2+ is required for payment requests');",
                  "});"
                ],
