    {
      "name": "01 - Pago Exitoso",
      "item": [
        {
          "name": "Create Charge - Success",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set('success_idempotency_key', `booking-success-${suffix}`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HU016: pago exitoso responde 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('HU016: backend confirma el pago', function () {",
                  "    pm.expect(body.status).to.eql('confirmed');",
                  "});",
                  "",
                  "pm.test('HU016: se genera recibo', function () {",
                  "    pm.expect(body.receipt_id).to.be.a('string');",
                  "    pm.expect(body.receipt_number).to.match(/^RCPT-/);",
                  "});",
                  "",
                  "pm.test('HU016: no se expone token de pago en la respuesta', function () {",
                  "    pm.expect(body.payment_method_token).to.eql(undefined);",
                  "});",
                  "",
                  "pm.test('HU016: no se expone PAN/CVV en la respuesta', function () {",
                  "    pm.expect(body.card_number).to.eql(undefined);",
                  "    pm.expect(body.cvv).to.eql(undefined);",
                  "});",
                  "",
                  "pm.collectionVariables.set('payment_id', body.payment_id);",
                  "pm.collectionVariables.set('confirmed_payment_id', body.payment_id);",
                  "pm.collectionVariables.set('confirmed_idempotency_key', pm.collectionVariables.get('success_idempotency_key'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Forwarded-Proto",
                "value": "https"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reservation_id\": \"{{reservation_id}}\",\n  \"traveler_id\": \"{{traveler_id}}\",\n  \"payment_method_token\": \"pm_tok_visa_ok\",\n  \"amount_in_cents\": 125000,\n  \"currency\": \"COP\",\n  \"idempotency_key\": \"{{success_idempotency_key}}\"\n}"
            },
            "url": {
              "raw": "{{payments_base_url}}/api/v1/payments/charges",
              "host": [
                "{{payments_base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "payments",
                "charges"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Payment By Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Consulta de pago responde 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('HU016: pago consultado sigue confirmado', function () {",
                  "    pm.expect(body.status).to.eql('confirmed');",
                  "});",
                  "",
                  "pm.test('HU016: recibo queda disponible al consultar el pago', function () {",
                  "    pm.expect(body.receipt_id).to.be.a('string');",
                  "    pm.expect(body.receipt_number).to.match(/^RCPT-/);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{payments_base_url}}/api/v1/payments/{{confirmed_payment_id}}",
              "host": [
                "{{payments_base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "payments",
                "{{confirmed_payment_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Payment Events - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Consulta de eventos responde 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const eventTypes = body.map(item => item.event_type);",
                  "",
                  "pm.test('HU016: existen eventos de confirmacion y recibo', function () {",
                  "    pm.expect(eventTypes).to.include('payment.succeeded');",
                  "    pm.expect(eventTypes).to.include('reservation.confirmation.requested');",
                  "    pm.expect(eventTypes).to.include('receipt.generated');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{payments_base_url}}/api/v1/payments/{{confirmed_payment_id}}/events",
              "host": [
                "{{payments_base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "payments",
                "{{confirmed_payment_id}}",
                "events"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "02 - Pago Fallido",
      "item": [
        {
          "name": "Create Charge - Failure",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set('failure_idempotency_key', `booking-failure-${suffix}`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HU016: pago fallido tambien responde 201 en el recurso de pago', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('HU016: backend marca el pago como failed', function () {",
                  "    pm.expect(body.status).to.eql('failed');",
                  "});",
                  "",
                  "pm.test('HU016: backend devuelve motivo claro de rechazo', function () {",
                  "    pm.expect(body.failure_reason).to.eql('insufficient_funds');",
                  "});",
                  "",
                  "pm.test('HU016: no se genera recibo en pago fallido', function () {",
                  "    pm.expect(body.receipt_id).to.eql(null);",
                  "    pm.expect(body.receipt_number).to.eql(null);",
                  "});",
                  "",
                  "pm.collectionVariables.set('failed_payment_id', body.payment_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Forwarded-Proto",
                "value": "https"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reservation_id\": \"{{reservation_id}}\",\n  \"traveler_id\": \"{{traveler_id}}\",\n  \"payment_method_token\": \"pm_fail_insufficient_funds\",\n  \"amount_in_cents\": 125000,\n  \"currency\": \"COP\",\n  \"idempotency_key\": \"{{failure_idempotency_key}}\"\n}"
            },
            "url": {
              "raw": "{{payments_base_url}}/api/v1/payments/charges",
              "host": [
                "{{payments_base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "payments",
                "charges"
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Payment Events - Failure",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Consulta de eventos de fallo responde 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const eventTypes = body.map(item => item.event_type);",
                  "",
                  "pm.test('HU016: pago fallido registra evento payment.failed', function () {",
                  "    pm.expect(eventTypes).to.include('payment.failed');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{payments_base_url}}/api/v1/payments/{{failed_payment_id}}/events",
              "host": [
                "{{payments_base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "payments",
                "{{failed_payment_id}}",
                "events"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "03 - Duplicados",
      "item": [
        {
          "name": "Create Charge - Duplicate Seed",
