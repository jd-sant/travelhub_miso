          "name": "Health - Payments",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Health responde 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('Health reporta healthy', function () {",
                  "    pm.expect(body.status).to.eql('healthy');",
                  "});"
