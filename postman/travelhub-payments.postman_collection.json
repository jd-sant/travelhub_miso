                  "pm.collectionVariables.set('duplicate_traveler_id', pm.variables.replaceIn('{{$randomUUID}}'));"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Seed para duplicado responde 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('duplicate_seed_payment_id', body.payment_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Forwarded-Proto",
                "value": "https"
